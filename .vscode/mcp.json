{
    "servers": {
        "docflow": {
            "type": "http",
            "url": "http://localhost:8000/mcp",
            "headers": {
            "Authorization": "Bearer ${input:docflowApiKey}"
            }
        }
    },
    "inputs": [
        {
            "id": "docflowApiKey",
            "type": "promptString",
            "description": "Docflow MCP API key",
            "password": true
        }
    ]
}