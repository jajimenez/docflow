# Docflow environment variables — copy this file to .env and fill in all required values.
# .env is gitignored; this file is committed as documentation of all required variables.

# ─── Production Docker Compose ───────────────────────────────────────────────
# Required when running docker-compose.yml.

# Airflow metadata database password
AIRFLOW_DB_PASSWORD=

# Airflow web UI / REST API admin password
AIRFLOW_ADMIN_PASSWORD=

# Airflow JWT signing key — generate with: openssl rand -base64 32
AIRFLOW_SECRET_KEY=

# Airflow Fernet key for encrypting connection passwords and variables in the metadata
# database.  IMPORTANT: keep this stable for the lifetime of the metadata database —
# regenerating it will make all previously encrypted data permanently unreadable.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# Knowledge database password (shared by Airflow connections and the MCP server)
KNOWLEDGE_DB_PASSWORD=

# MCP server API key — used by clients to authenticate requests.
# Generate with: openssl rand -base64 32
DOCFLOW_MCP_API_KEY=

# Host paths for PDF processing directories — bind-mounted into the Airflow containers.
# Absolute paths are recommended.  The directories are created automatically if absent.
PDF_PENDING_DIR=/path/to/pdf/pending
PDF_PROCESSED_DIR=/path/to/pdf/processed
PDF_FAILED_DIR=/path/to/pdf/failed

# ─── Docflow application (running directly, without Docker) ──────────────────
# Required when running the Docflow application outside of Docker (e.g. in the dev
# container or in a local virtual environment). Not needed for docker-compose.yml,
# which sets these values directly in the service definitions.

# PDF directories (relative or absolute paths on the host)
DOCFLOW_PDF_PENDING_DIR=
DOCFLOW_PDF_PROCESSED_DIR=
DOCFLOW_PDF_FAILED_DIR=

# Docling text extraction models path
DOCFLOW_PDF_EXTRACTION_MODELS_PATH=

# Document chunks (optional)
# DOCFLOW_CHUNK_SIZE=1000
# DOCFLOW_CHUNK_OVERLAP=200

# Ollama embeddings API
DOCFLOW_EMBEDDINGS_API_URL=
# DOCFLOW_EMBEDDINGS_API_TIMEOUT=30
# DOCFLOW_EMBEDDINGS_MODEL=nomic-embed-text:v1.5
# DOCFLOW_EMBEDDINGS_DIMENSION=768

# Knowledge database
DOCFLOW_KNOWLEDGE_DB_HOST=
DOCFLOW_KNOWLEDGE_DB_USER=
DOCFLOW_KNOWLEDGE_DB_PASSWORD=
# DOCFLOW_KNOWLEDGE_DB_PORT=5432
DOCFLOW_KNOWLEDGE_DB_NAME=
