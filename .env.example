# Docflow environment variables — copy this file to .env and fill in your values.
# .env is gitignored; this file is committed as documentation of all required variables.
# Variables marked "(default: ...)" are optional when running locally.

# PDF files
DOCFLOW_PDF_PENDING_DIR=pending
DOCFLOW_PDF_PROCESSED_DIR=processed
DOCFLOW_PDF_FAILED_DIR=failed

# Docling text extraction models
DOCFLOW_EXTRACTION_MODELS_PATH=

# Document chunks (optional)
# DOCFLOW_CHUNK_SIZE=1000
# DOCFLOW_CHUNK_OVERLAP=200

# Ollama embeddings API
DOCFLOW_EMBEDDINGS_API_URL=
# DOCFLOW_EMBEDDINGS_API_TIMEOUT=30
# DOCFLOW_EMBEDDINGS_MODEL=nomic-embed-text:v1.5
# DOCFLOW_EMBEDDINGS_DIMENSION=768

# Knowledge database
DOCFLOW_KNOWLEDGE_DB_URL=
